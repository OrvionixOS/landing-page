# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/listingstudio"

# NextAuth v5 JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# AES-256-GCM key for encrypting Etsy OAuth tokens at rest (Phase 2, not yet wired up).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# Anthropic Claude API key for the centralized AI service (src/lib/ai). Required
# before Brand Engine / Listing Generator endpoints will function — leave unset
# to develop everything else first.
ANTHROPIC_API_KEY=""

# Etsy Open API v3 "Keystring" (Phase 2). Used both as the OAuth client_id for
# the PKCE connect flow (src/lib/etsy/oauth.ts) and as the x-api-key header on
# every Etsy API call (src/lib/etsy/client.ts). Get one at
# https://www.etsy.com/developers/your-apps — leave unset to develop
# everything else first; the Etsy connect/disconnect/publish routes will
# throw until it's set.
ETSY_CLIENT_ID=""

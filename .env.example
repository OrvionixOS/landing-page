# PostgreSQL connection string. In production (e.g. on Vercel), use a
# provider whose driver tolerates serverless functions opening many short
# connections — Neon, Supabase, or Vercel Postgres all work; if you use
# plain Postgres behind PgBouncer, append `?pgbouncer=true` per Prisma's
# docs.
DATABASE_URL="postgresql://user:password@localhost:5432/listingstudio"

# NextAuth v5 JWT signing secret. Generate with: openssl rand -base64 32
# Use a different value in production than in development, and never commit
# the real value — only this placeholder file is checked in.
AUTH_SECRET=""

# AES-256-GCM key for encrypting Etsy OAuth tokens at rest
# (src/lib/security/encryption.ts). Generate with: openssl rand -base64 32
# Losing/rotating this key invalidates every stored Etsy connection (sellers
# would need to reconnect), so back it up the same way you back up
# AUTH_SECRET.
ENCRYPTION_KEY=""

# Anthropic Claude API key for the centralized AI service (src/lib/ai). Required
# before Brand Engine / Listing Generator endpoints will function — leave unset
# to develop everything else first.
ANTHROPIC_API_KEY=""

# Etsy Open API v3 "Keystring", from https://www.etsy.com/developers/your-apps.
# Used both as the OAuth client_id for the PKCE connect flow
# (src/lib/etsy/oauth.ts) and as the x-api-key header on every Etsy API call
# (src/lib/etsy/client.ts) — leave unset to develop everything else first;
# the Etsy connect/disconnect/publish routes will throw until it's set.
#
# Production setup: in your Etsy app's settings, add this exact callback URL
# to its allowed Redirect URIs list (no env var needed for it — the app
# derives it from the live request automatically):
#   https://<your-production-domain>/api/etsy/callback
# e.g. https://listingstudio.yourdomain.com/api/etsy/callback or
#      https://<your-vercel-project>.vercel.app/api/etsy/callback
# Etsy will reject the OAuth callback with a redirect_uri mismatch if this
# isn't registered exactly (scheme, host, and path must match).
ETSY_CLIENT_ID=""
